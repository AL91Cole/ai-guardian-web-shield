{
  "manifest_version": 3,
  "name": "AI Guardian Web Shield",
  "version": "1.0.0",
  "description": "A privacy-first helper that checks links and pages on your device using calm, plain-language guidance.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "sidePanel",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AI Guardian Web Shield",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js",
        "shared/debounce.js",
        "shared/domUtils.js",
        "shared/urlUtils.js",
        "email/emailState.js",
        "email/providerDetection.js",
        "email/emailHeuristics.js",
        "email/inboxRowScanner.js",
        "email/messageLinkScanner.js",
        "email/pageModeDetection.js",
        "email/authFlowHandler.js",
        "email/emailUiInjector.js",
        "email/emailSafetyController.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
